DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
MUSIC_CHANNEL_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
METRICS_PORT=9090
# Set to your VPS Tailscale IP (run: tailscale ip -4) to expose metrics only on Tailscale
# Defaults to 127.0.0.1 (localhost only) if not set
METRICS_BIND_IP=127.0.0.1
# Route yt-dlp through a SOCKS5 proxy to bypass VPS IP blocks (optional)
# Set to your Mac's Tailscale IP running: microsocks -i <mac-tailscale-ip> -p 1080
# YT_PROXY=socks5h://100.x.x.x:1080
